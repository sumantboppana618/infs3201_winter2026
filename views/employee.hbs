<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8" />
  <title>Employee Details</title>
  <link rel="stylesheet" href="/styles.css">
</head>
<body>
  <div class="container">
    <h1>{{employee.name}}</h1>
    <p><a href="/logout">Logout</a></p>
    <p>Phone: {{employee.phone}}</p>
    {{#if employee.photo}}
      <p><img src="{{employee.photo}}" alt="{{employee.name}} photo" width="180"></p>
    {{/if}}
    <p>
      <a href="/employee/{{employee.id}}/edit">Edit Details</a> |
      <a href="/">Back</a>
    </p>

    <h2>Shifts</h2>

    <table>
      <tr>
        <th>Date</th>
        <th>Start</th>
        <th>End</th>
      </tr>
      {{#each shifts}}
        <tr>
          <td>{{this.date}}</td>
          <td class="{{this.startClass}}">{{this.startTime}}</td>
          <td>{{this.endTime}}</td>
        </tr>
      {{/each}}
    </table>

    <h2 id="docs">Documents</h2>
    {{#if hasDocuments}}
      <ul>
        {{#each documents}}
          <li>
            <a href="/employee/{{../employee.id}}/docs/{{this.id}}">{{this.originalName}}</a>
            ({{this.size}} bytes, uploaded {{this.uploadedAt}})
          </li>
        {{/each}}
      </ul>
    {{else}}
      <p>No documents uploaded.</p>
    {{/if}}

    <h3>Upload PDF (max 2MB, max 5 docs)</h3>
    <form method="post" action="/employee/{{employee.id}}/docs" enctype="multipart/form-data">
      <input type="file" name="document" accept="application/pdf" required />
      <button type="submit">Upload</button>
    </form>
  </div>
</body>
</html>
