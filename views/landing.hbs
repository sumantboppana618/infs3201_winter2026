<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8">
  <title>Employees</title>
  <link rel="stylesheet" href="/styles.css">
</head>
<body>
  <div class="container">
    <h1>Employees</h1>
    <ul>
      {{#each employees}}
        <li>
          <a href="/employee/{{this.employeeId}}">
            {{this.name}}
          </a>
        </li>
      {{/each}}
    </ul>
  </div>
</body>
</html>